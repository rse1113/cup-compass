# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Skimlinks catch-all fallback (publisher ID, safe to expose client-side)
VITE_SKIMLINKS_PUBLISHER_ID=305387X179359

# Server-only secrets (Vercel serverless functions, NOT exposed to the client)
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
